#!/bin/bash
# Check if tap formulae are outdated compared to homebrew-core
#
# Usage: ./check-upstream
#        Or add to PATH and run: check-upstream

set -e

TAP="wolfman/macos1015-fixes"
TAP_PATH="/usr/local/Homebrew/Library/Taps/wolfman/homebrew-macos1015-fixes/Formula"

echo "Comparing $TAP formulae against homebrew-core..."
echo

outdated=0
current=0

for formula in "$TAP_PATH"/*.rb; do
    name=$(basename "$formula" .rb)
    
    # Get versions using brew info JSON
    tap_info=$(brew info --json=v2 "$TAP/$name" 2>/dev/null || echo '{}')
    core_info=$(brew info --json=v2 "$name" 2>/dev/null || echo '{}')
    
    tap_ver=$(echo "$tap_info" | python3 -c "import sys,json; d=json.load(sys.stdin); f=d.get('formulae',[]); print(f[0]['versions']['stable'] if f else '')" 2>/dev/null)
    core_ver=$(echo "$core_info" | python3 -c "import sys,json; d=json.load(sys.stdin); f=d.get('formulae',[]); print(f[0]['versions']['stable'] if f else '')" 2>/dev/null)
    
    tap_rev=$(echo "$tap_info" | python3 -c "import sys,json; d=json.load(sys.stdin); f=d.get('formulae',[]); print(f[0].get('revision',0) if f else 0)" 2>/dev/null)
    core_rev=$(echo "$core_info" | python3 -c "import sys,json; d=json.load(sys.stdin); f=d.get('formulae',[]); print(f[0].get('revision',0) if f else 0)" 2>/dev/null)
    
    # Format with revision if present
    tap_full="$tap_ver"
    core_full="$core_ver"
    [[ "$tap_rev" -gt 0 ]] && tap_full="${tap_ver}_${tap_rev}"
    [[ "$core_rev" -gt 0 ]] && core_full="${core_ver}_${core_rev}"
    
    if [[ -z "$core_ver" ]]; then
        echo "⚠  $name: not found in homebrew-core"
    elif [[ "$tap_full" != "$core_full" ]]; then
        echo "⬆  $name: $tap_full → $core_full (needs update)"
        ((outdated++))
    else
        echo "✓  $name: $tap_full"
        ((current++))
    fi
done

echo
echo "Summary: $outdated outdated, $current current"

if [[ $outdated -gt 0 ]]; then
    exit 1
fi
